{
    "interface_version": 2,
    "name": "MaaHKWorld",
    "label": "王者荣耀世界自动化助手",
    "title": "MaaHKWorld v1.0.0",
    "version": "1.0.0",
    "description": "基于图像识别的王者荣耀世界自动化助手，目前仅实现了自动钓鱼",
    "agent": {
        "child_exec": "../../venv/Scripts/python.exe",
        "child_args": [
            "../../agent/start_agent.py"
        ]
    },
    "controller": [
        {
            "name": "Windows",
            "label": "Windows桌面",
            "type": "Win32",
            "display_raw": true,
            "win32": {
                "class_regex": "UnrealWindow",
                "window_regex": "王者荣耀世界",
                "screencap": "FramePool",
                "mouse": "SendMessage",
                "keyboard": "SendMessage"
            }
        }
    ],
    "resource": [
        {
            "name": "FishingResource",
            "label": "钓鱼资源",
            "path": [
                "../../assets/resource"
            ]
        }
    ],
    "task": [
        {
            "name": "StartFishing",
            "label": "自动钓鱼",
            "entry": "激活游戏窗口",
            "default_check": true,
            "description": "自动执行钓鱼操作，包括抛竿、拉杆、连点等"
        }
    ],
    "option": {}
}
